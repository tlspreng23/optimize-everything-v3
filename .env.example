# Backend environment variables (set as Modal secrets)
# Run: modal secret create optimize-everything-secrets \
#        SUPABASE_URL="..." SUPABASE_SERVICE_KEY="..."
# Run: modal secret create optimize-everything-key \
#        ANTHROPIC_API_KEY="..."

SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_KEY=<service_role_secret_key>
ANTHROPIC_API_KEY=<your_anthropic_api_key>

# Frontend (update frontend/js/config.js after Modal deploy)
# MODAL_API_URL=https://<workspace>--optimize-everything-v3-api-fastapi-app.modal.run
